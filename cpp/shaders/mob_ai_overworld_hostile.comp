    mob.state_timer++;

    float dist;
    uint target = find_nearest_entity(mob.position, CREEPER_DETECTION_RANGE, dist);
    if (target != 0xFFFFFFFF) {
        mob.target_entity_id = target;
        mob.ai_state = AI_STATE_CHASE;
        mob.state_timer = 0;
        return;
    }

    if (mob.state_timer > 40 + uint(random_float(seed) * 60.0)) {
        mob.ai_state = AI_STATE_WANDER;
