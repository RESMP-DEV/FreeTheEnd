void creeper_chase(inout MobState mob, inout uint seed) {
    mob.state_timer++;

    if (!entity_exists(mob.target_entity_id)) {
        mob.ai_state = AI_STATE_IDLE;
        mob.target_entity_id = 0xFFFFFFFF;
        mob.state_timer = 0;
        return;
    }

    vec3 target_pos = get_entity_position(mob.target_entity_id);
    float dist = distance(mob.position, target_pos);

    // Lost target
    if (dist > CREEPER_DETECTION_RANGE * 1.5) {
        mob.ai_state = AI_STATE_IDLE;
        mob.target_entity_id = 0xFFFFFFFF;
        mob.state_timer = 0;
        return;
    }

    // In fuse range - start hissing
    if (dist < CREEPER_FUSE_RANGE) {
        mob.ai_state = AI_STATE_FUSE;
        mob.type_data[TD_CREEPER_FUSE_TIMER] = 0;
        mob.type_data[TD_CREEPER_IGNITED] = 1;
        mob.state_timer = 0;
        return;
    }

    // Chase silently (creepers don't make footstep sounds)
    mob.path_target = pathfind_step(mob.position, target_pos, seed);
    move_toward(mob, mob.path_target, CREEPER_SPEED);
    check_jump_obstacle(mob);
}

void creeper_fuse(inout MobState mob, inout uint seed) {
    mob.state_timer++;
    mob.type_data[TD_CREEPER_FUSE_TIMER]++;

    if (!entity_exists(mob.target_entity_id)) {
        // Target gone, defuse
        mob.ai_state = AI_STATE_IDLE;
        mob.target_entity_id = 0xFFFFFFFF;
        mob.type_data[TD_CREEPER_FUSE_TIMER] = 0;
        mob.type_data[TD_CREEPER_IGNITED] = 0;
        mob.state_timer = 0;
        return;
    }

    vec3 target_pos = get_entity_position(mob.target_entity_id);
    float dist = distance(mob.position, target_pos);

    // Target moved away - defuse
    if (dist > CREEPER_DEFUSE_RANGE) {
        // Fuse decreases when target leaves
        if (mob.type_data[TD_CREEPER_FUSE_TIMER] > 0) {
            mob.type_data[TD_CREEPER_FUSE_TIMER]--;
        }
        if (mob.type_data[TD_CREEPER_FUSE_TIMER] == 0) {
            mob.ai_state = AI_STATE_CHASE;
            mob.type_data[TD_CREEPER_IGNITED] = 0;
            mob.state_timer = 0;
        }
        return;
    }

    // Face target while fusing
    mob.yaw = angle_to(mob.position, target_pos);

    // Slow down / stop while fusing
    mob.velocity.x *= 0.3;
    mob.velocity.z *= 0.3;

    // EXPLODE
    float max_fuse = uintBitsToFloat(mob.type_data[TD_CREEPER_MAX_FUSE]);
    if (max_fuse == 0.0) max_fuse = CREEPER_FUSE_TIME;

    if (float(mob.type_data[TD_CREEPER_FUSE_TIMER]) >= max_fuse) {
        // Create explosion
        uint idx = atomicAdd(explosion_count, 1);
        if (idx < 32) {
            float radius = uintBitsToFloat(mob.type_data[TD_CREEPER_EXPLOSION_RADIUS]);
            if (radius == 0.0) radius = CREEPER_EXPLOSION_RADIUS;

            // Charged creepers have double radius
            if (mob.type_data[TD_CREEPER_CHARGED] == 1) {
                radius *= 2.0;
            }

            explosions[idx].position = mob.position;
            explosions[idx].radius = radius;
            explosions[idx].damage = radius * 10.0;  // Damage scales with radius
            explosions[idx].source_entity = 0;
        }

        // Kill creeper
        mob.health = 0.0;
        mob.ai_state = AI_STATE_DEAD;
    }
}

void update_creeper(inout MobState mob, float dt, inout uint seed) {
    switch (mob.ai_state) {
        case AI_STATE_IDLE:
            creeper_idle(mob, seed);
            break;
        case AI_STATE_WANDER:
            creeper_wander(mob, seed);
            break;
        case AI_STATE_CHASE:
            creeper_chase(mob, seed);
            break;
        case AI_STATE_FUSE:
            creeper_fuse(mob, seed);
            break;
    }
}

// ============================================================================
// Main
// ============================================================================

void main() {
    uint idx = gl_GlobalInvocationID.x;
    if (idx >= pc.mob_count) return;

    MobState mob = mobs[idx];

    // Only process overworld hostiles
    bool is_overworld_hostile = (mob.mob_type == MOB_TYPE_ZOMBIE ||
                                  mob.mob_type == MOB_TYPE_SKELETON ||
                                  mob.mob_type == MOB_TYPE_SPIDER ||
                                  mob.mob_type == MOB_TYPE_CREEPER);
    if (!is_overworld_hostile) return;
    if (mob.ai_state == AI_STATE_DEAD || (mob.flags & MOB_FLAG_NO_AI) != 0) return;

    uint seed = mob.random_seed ^ pc.random_seed ^ idx;
    float dt = pc.delta_time;

    // Update timers
    mob.hurt_time = max(mob.hurt_time - 1, 0);
    mob.no_damage_time = max(mob.no_damage_time - 1, 0);
    mob.ai_tick_cooldown = max(mob.ai_tick_cooldown - 1, 0);

    // Despawn check (> 128 blocks from any player)
    if ((mob.flags & MOB_FLAG_CAN_DESPAWN) != 0) {
        float player_dist = distance(mob.position, pc.player_pos);
        if (player_dist > 128.0) {
            mob.ai_state = AI_STATE_DEAD;
            mobs[idx] = mob;
            return;
        }
    }

    // AI tick
    if (mob.ai_tick_cooldown == 0) {
        mob.ai_tick_cooldown = 2;

        switch (mob.mob_type) {
            case MOB_TYPE_ZOMBIE:
                update_zombie(mob, dt, seed);
                break;
            case MOB_TYPE_SKELETON:
                update_skeleton(mob, dt, seed);
                break;
            case MOB_TYPE_SPIDER:
                update_spider(mob, dt, seed);
                break;
            case MOB_TYPE_CREEPER:
                update_creeper(mob, dt, seed);
                break;
        }
    }

    // Physics (except climbing spiders)
    if (mob.type_data[TD_SPIDER_CLIMBING] != 1 || mob.mob_type != MOB_TYPE_SPIDER) {
        if ((mob.flags & MOB_FLAG_ON_GROUND) == 0) {
            mob.velocity.y -= GRAVITY * dt * 20.0;
            mob.velocity.y = max(mob.velocity.y, -TERMINAL_VELOCITY);
        }
    }

    // Drag
    float drag = ((mob.flags & MOB_FLAG_IN_WATER) != 0) ? DRAG_WATER : DRAG_AIR;
    mob.velocity *= (1.0 - drag);

    // Apply velocity
    mob.position += mob.velocity * dt * 20.0;

    // Death check
    if (mob.health <= 0.0) {
        mob.ai_state = AI_STATE_DEAD;
    }

    mob.random_seed = seed;
    mobs[idx] = mob;
}
