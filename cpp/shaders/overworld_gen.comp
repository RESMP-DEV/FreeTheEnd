            baseHeight = 62.0; heightVariation = 8.0; hilliness = 0.6; break;

        case BIOME_PLAINS:
            baseHeight = 64.0; heightVariation = 3.0; hilliness = 0.15; break;
        case BIOME_FOREST:
        case BIOME_BIRCH_FOREST:
