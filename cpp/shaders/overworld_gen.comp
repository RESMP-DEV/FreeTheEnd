            baseHeight = 66.0; heightVariation = 6.0; hilliness = 0.3; break;
        case BIOME_TAIGA:
        case BIOME_COLD_TAIGA:
            baseHeight = 66.0; heightVariation = 8.0; hilliness = 0.35; break;
        case BIOME_MEGA_TAIGA:
            baseHeight = 68.0; heightVariation = 10.0; hilliness = 0.4; break;

        case BIOME_EXTREME_HILLS:
        case BIOME_EXTREME_HILLS_PLUS:
        case BIOME_EXTREME_HILLS_EDGE:
            baseHeight = 72.0; heightVariation = 48.0; hilliness = 0.8; break;
        case BIOME_ICE_MOUNTAINS:
            baseHeight = 70.0; heightVariation = 40.0; hilliness = 0.7; break;

        case BIOME_JUNGLE:
        case BIOME_JUNGLE_HILLS:
            baseHeight = 68.0; heightVariation = 12.0; hilliness = 0.45; break;

        case BIOME_SWAMPLAND:
            baseHeight = 61.0; heightVariation = 2.0; hilliness = 0.05; break;

        case BIOME_DESERT:
        case BIOME_DESERT_HILLS:
            baseHeight = 66.0; heightVariation = 5.0; hilliness = 0.25; break;

        case BIOME_SAVANNA:
            baseHeight = 65.0; heightVariation = 4.0; hilliness = 0.2; break;
        case BIOME_SAVANNA_PLATEAU:
            baseHeight = 80.0; heightVariation = 3.0; hilliness = 0.15; break;

        case BIOME_MESA:
        case BIOME_MESA_PLATEAU:
