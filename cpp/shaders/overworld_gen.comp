// ============================================================================
// Java-compatible random number generator (LC 1.8.9 world seed algorithm)
// ============================================================================

// Java LCG: next = (seed * 0x5DEECE66DL + 0xBL) & ((1L << 48) - 1)
// Returns upper 32 bits as int
uint javaRandom(inout uint seed) {
    // Split into high and low parts for 48-bit arithmetic
    uint lo = seed & 0xFFFFu;
    uint hi = seed >> 16;

    // Multiply by 0x5DEECE66D (split into parts)
    uint mult_lo = 0xE66Du;
    uint mult_hi = 0x5DEECu;

    uint result_lo = lo * mult_lo;
    uint result_mid1 = lo * mult_hi;
    uint result_mid2 = hi * mult_lo;
    uint result_hi = hi * mult_hi;

    // Combine with carry
    result_lo += 0xBu;  // Add constant
    result_mid1 += result_lo >> 16;
    result_mid2 += result_mid1 & 0xFFFFu;

    // Extract 48-bit result
    seed = ((result_mid2 & 0xFFFFu) << 16) | (result_lo & 0xFFFFu);

    return seed >> 17;  // Return upper bits
}

// Initialize seed from world seed + chunk coords
uint initChunkSeed(int worldSeed, int chunkX, int chunkZ) {
    uint seed = uint(worldSeed);
    // Lower 32 bits of Java's 341873128712 and 132897987541
    seed = seed ^ (uint(chunkX) * 0x9939F508u) ^ (uint(chunkZ) * 0xF1565DC5u);
    return seed;
}

// ============================================================================
// Perlin Noise Implementation (matching MC 1.8.9)
// ============================================================================

float fade(float t) {
    return t * t * t * (t * (t * 6.0 - 15.0) + 10.0);
}

float grad(int hash, float x, float y, float z) {
    int h = hash & 15;
    float u = h < 8 ? x : y;
    float v = h < 4 ? y : (h == 12 || h == 14 ? x : z);
    return ((h & 1) == 0 ? u : -u) + ((h & 2) == 0 ? v : -v);
}

float grad2(int hash, float x, float y) {
    int h = hash & 7;
    float u = h < 4 ? x : y;
    float v = h < 4 ? y : x;
    return ((h & 1) == 0 ? u : -u) + ((h & 2) == 0 ? v : -v);
}

float perlin3D(vec3 p) {
    int X = int(floor(p.x)) & 255;
    int Y = int(floor(p.y)) & 255;
    int Z = int(floor(p.z)) & 255;
    float x = fract(p.x);
    float y = fract(p.y);
    float z = fract(p.z);
    float u = fade(x);
    float v = fade(y);
    float w = fade(z);

    int A  = perm_table.perm[X] + Y;
    int AA = perm_table.perm[A] + Z;
    int AB = perm_table.perm[A + 1] + Z;
    int B  = perm_table.perm[X + 1] + Y;
    int BA = perm_table.perm[B] + Z;
    int BB = perm_table.perm[B + 1] + Z;

    return mix(
        mix(mix(grad(perm_table.perm[AA], x, y, z),
                grad(perm_table.perm[BA], x - 1.0, y, z), u),
            mix(grad(perm_table.perm[AB], x, y - 1.0, z),
                grad(perm_table.perm[BB], x - 1.0, y - 1.0, z), u), v),
        mix(mix(grad(perm_table.perm[AA + 1], x, y, z - 1.0),
                grad(perm_table.perm[BA + 1], x - 1.0, y, z - 1.0), u),
            mix(grad(perm_table.perm[AB + 1], x, y - 1.0, z - 1.0),
                grad(perm_table.perm[BB + 1], x - 1.0, y - 1.0, z - 1.0), u), v), w);
}

float perlin2D(vec2 p) {
    int X = int(floor(p.x)) & 255;
    int Y = int(floor(p.y)) & 255;
    float x = fract(p.x);
    float y = fract(p.y);
    float u = fade(x);
    float v = fade(y);

    int A = perm_table.perm[X] + Y;
    int B = perm_table.perm[X + 1] + Y;

    return mix(
        mix(grad2(perm_table.perm[A], x, y),
            grad2(perm_table.perm[B], x - 1.0, y), u),
        mix(grad2(perm_table.perm[A + 1], x, y - 1.0),
            grad2(perm_table.perm[B + 1], x - 1.0, y - 1.0), u), v);
}

// Octave noise (fractal Brownian motion)
float fbm2D(vec2 p, int octaves, float persistence) {
    float total = 0.0;
    float amplitude = 1.0;
    float frequency = 1.0;
    float maxValue = 0.0;

    for (int i = 0; i < octaves; i++) {
        total += perlin2D(p * frequency) * amplitude;
        maxValue += amplitude;
        amplitude *= persistence;
        frequency *= 2.0;
    }
    return total / maxValue;
}

float fbm3D(vec3 p, int octaves, float persistence) {
    float total = 0.0;
    float amplitude = 1.0;
    float frequency = 1.0;
    float maxValue = 0.0;

    for (int i = 0; i < octaves; i++) {
        total += perlin3D(p * frequency) * amplitude;
        maxValue += amplitude;
        amplitude *= persistence;
        frequency *= 2.0;
    }
    return total / maxValue;
}

// Simplex-like noise variant for biome blending
float simplexLike2D(vec2 p) {
    vec2 i = floor(p + (p.x + p.y) * 0.366025403784);
    vec2 x0 = p - i + (i.x + i.y) * 0.211324865405;

    vec2 i1 = (x0.x > x0.y) ? vec2(1.0, 0.0) : vec2(0.0, 1.0);
    vec2 x1 = x0 - i1 + 0.211324865405;
    vec2 x2 = x0 - 1.0 + 2.0 * 0.211324865405;

    ivec2 ii = ivec2(i) & 255;
    int g0 = perm_table.perm[ii.x + perm_table.perm[ii.y]];
    int g1 = perm_table.perm[ii.x + int(i1.x) + perm_table.perm[ii.y + int(i1.y)]];
    int g2 = perm_table.perm[ii.x + 1 + perm_table.perm[ii.y + 1]];

    float n0, n1, n2;
    float t0 = 0.5 - dot(x0, x0);
    n0 = (t0 < 0.0) ? 0.0 : pow(t0, 4.0) * grad2(g0, x0.x, x0.y);

    float t1 = 0.5 - dot(x1, x1);
    n1 = (t1 < 0.0) ? 0.0 : pow(t1, 4.0) * grad2(g1, x1.x, x1.y);

    float t2 = 0.5 - dot(x2, x2);
    n2 = (t2 < 0.0) ? 0.0 : pow(t2, 4.0) * grad2(g2, x2.x, x2.y);

    return 70.0 * (n0 + n1 + n2);
}

// ============================================================================
// Biome Generation (MC 1.8.9 temperature/humidity algorithm)
// ============================================================================

// Temperature noise at coordinate
float getTemperature(vec2 worldXZ) {
    // MC uses large-scale noise for temperature
    float temp = fbm2D(worldXZ * 0.0005, 4, 0.5);
    // Add medium-scale variation
    temp += fbm2D(worldXZ * 0.002, 2, 0.5) * 0.25;
    return temp * 0.5 + 0.5;  // Normalize to 0-1
}

// Humidity/rainfall noise at coordinate
float getHumidity(vec2 worldXZ) {
    // Offset from temperature for variation
    float humid = fbm2D(worldXZ * 0.0006 + vec2(1000.0, 2000.0), 4, 0.5);
    humid += fbm2D(worldXZ * 0.003 + vec2(3000.0, 4000.0), 2, 0.5) * 0.25;
    return humid * 0.5 + 0.5;  // Normalize to 0-1
}

// Continentalness (land vs ocean)
float getContinentalness(vec2 worldXZ) {
    float cont = fbm2D(worldXZ * 0.0003, 6, 0.5);
    return cont;
}

// River noise
float getRiverNoise(vec2 worldXZ) {
    float river = abs(fbm2D(worldXZ * 0.001, 3, 0.5));
    return river;
}

// Determine biome from climate parameters
uint determineBiome(float temp, float humid, float continental, float river) {
    // River check first
    if (river < 0.03 && continental > -0.1) {
        return (temp < 0.15) ? BIOME_FROZEN_RIVER : BIOME_RIVER;
    }

    // Ocean check
    if (continental < -0.3) {
        if (continental < -0.5) {
            return BIOME_DEEP_OCEAN;
        }
        return (temp < 0.2) ? BIOME_FROZEN_OCEAN : BIOME_OCEAN;
    }

    // Beach transition
    if (continental < -0.15 && continental > -0.3) {
        if (temp < 0.2) return BIOME_COLD_BEACH;
        if (temp > 0.8 && humid < 0.3) return BIOME_BEACH;
        return BIOME_BEACH;
    }

    // Land biomes based on temperature and humidity
    // Cold biomes (temp < 0.2)
    if (temp < 0.2) {
        if (humid > 0.6) return BIOME_COLD_TAIGA;
        if (humid > 0.3) return BIOME_ICE_MOUNTAINS;
        return BIOME_ICE_PLAINS;
    }

    // Cool biomes (temp 0.2 - 0.4)
    if (temp < 0.4) {
        if (humid > 0.7) return BIOME_MEGA_TAIGA;
        if (humid > 0.4) return BIOME_TAIGA;
        return BIOME_EXTREME_HILLS;
    }

    // Temperate biomes (temp 0.4 - 0.7)
    if (temp < 0.7) {
        if (humid > 0.8) return BIOME_ROOFED_FOREST;
        if (humid > 0.6) return BIOME_FOREST;
        if (humid > 0.4) return BIOME_BIRCH_FOREST;
        if (humid > 0.2) return BIOME_PLAINS;
        return BIOME_EXTREME_HILLS;
    }

    // Warm biomes (temp 0.7 - 0.85)
    if (temp < 0.85) {
        if (humid > 0.75) return BIOME_JUNGLE;
        if (humid > 0.5) return BIOME_SWAMPLAND;
        if (humid > 0.25) return BIOME_SAVANNA;
        return BIOME_PLAINS;
    }

    // Hot biomes (temp >= 0.85)
    if (humid < 0.15) return BIOME_MESA;
    if (humid < 0.3) return BIOME_DESERT;
    if (humid > 0.6) return BIOME_JUNGLE;
    return BIOME_SAVANNA;
}

