#version 450

/*
 * quick_craft.comp - Context-sensitive quick crafting for RL speedrun training
 *
 * Single action crafts the most useful available item based on speedrun progression.
 * Priority order optimized for "Free The End" (spawn to dragon kill):
 *
 *  1. Eyes of Ender (if have blaze powder + ender pearls)
 *  2. Blaze powder (if have blaze rods, need eyes)
 *  3. Iron pickaxe (if have iron ingots, need diamond/obsidian)
 *  4. Stone pickaxe (if have cobblestone, need iron)
 *  5. Wooden pickaxe (if have planks, need stone/cobble)
 *  6. Crafting table (if none, have planks)
 *  7. Planks (if have logs, need anything)
 *  8. Sticks (if have planks, need tools)
 *  9. Furnace (if have cobblestone, need smelting)
 * 10. Bucket (if have iron ingots)
 *
 * Integrates with inventory_ops.comp slot layout and crafting.comp recipe system.
 */

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

// ============================================================================
// MINECRAFT 1.8.9 ITEM IDS
// ============================================================================

