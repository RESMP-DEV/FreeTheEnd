#version 450
#extension GL_EXT_shader_explicit_arithmetic_types_int64 : enable

// Nether terrain generation compute shader
// Generates hellish landscape with lava oceans, large caverns, and netherrack

layout(local_size_x = 8, local_size_y = 8, local_size_z = 8) in;

// Block types
const uint BLOCK_AIR = 0;
const uint BLOCK_BEDROCK = 7;
const uint BLOCK_NETHERRACK = 87;
const uint BLOCK_SOUL_SAND = 88;
const uint BLOCK_GLOWSTONE = 89;
const uint BLOCK_LAVA = 11;
const uint BLOCK_NETHER_QUARTZ_ORE = 153;

// Terrain constants
const int NETHER_HEIGHT = 128;
const int BEDROCK_CEILING = 127;
const int LAVA_LEVEL = 31;
const float CAVE_THRESHOLD = 0.2;

// Noise parameters for large nether caverns
const float CAVE_SCALE = 0.04;      // Larger caves than overworld
const float CAVE_SCALE_Y = 0.06;    // Vertical stretch
const int CAVE_OCTAVES = 3;

layout(std430, binding = 0) buffer ChunkData {
    uint blocks[];
};

layout(push_constant) uniform PushConstants {
    ivec3 chunkPos;      // Chunk position in world (chunk coordinates)
    uint seed;           // World seed
    float caveFrequency; // Cave density multiplier
    float lavaChance;    // Additional lava pocket chance
} pc;

