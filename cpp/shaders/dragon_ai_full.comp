// ============================================================================
// UTILITIES
// ============================================================================

uint hash(uint x) {
    x ^= x >> 16;
    x *= 0x85ebca6bu;
    x ^= x >> 13;
    x *= 0xc2b2ae35u;
    x ^= x >> 16;
    return x;
}

float rand(inout uint seed) {
    seed = hash(seed);
    return float(seed) / 4294967295.0;
}

float rand_range(inout uint seed, float a, float b) {
    return a + rand(seed) * (b - a);
}

float clamp01(float x) { return clamp(x, 0.0, 1.0); }

float ease_out_cubic(float t) {
    return 1.0 - pow(1.0 - t, 3.0);
}

float ease_in_out_quad(float t) {
    return t < 0.5 ? 2.0 * t * t : 1.0 - pow(-2.0 * t + 2.0, 2.0) / 2.0;
}

// Smooth steering toward target position
vec3 steer_toward(vec3 current_pos, vec3 current_vel, vec3 target, float max_speed, float turn_rate) {
    vec3 desired = target - current_pos;
    float dist = length(desired);
    if (dist < 0.001) return current_vel;

    desired = normalize(desired) * max_speed;
    vec3 steering = desired - current_vel;
    float steer_len = length(steering);
    if (steer_len > turn_rate) {
        steering = steering / steer_len * turn_rate;
    }
    return current_vel + steering;
}

// Count alive crystals for an environment
uint count_alive_crystals(uint env_id) {
    uint base = env_id * NUM_CRYSTALS;
    uint count = 0u;
    for (uint i = 0u; i < NUM_CRYSTALS; i++) {
        if (crystals[base + i].is_alive > 0.5) count++;
    }
    return count;
}

// Update dragon facing based on velocity
void update_dragon_facing(inout Dragon d) {
    float speed = length(d.velocity);
    if (speed > 0.01) {
        // Yaw from XZ direction
        d.yaw = degrees(atan(d.velocity.x, d.velocity.z));
        // Pitch from vertical component
        d.body_pitch = degrees(asin(clamp(-d.velocity.y / speed, -1.0, 1.0)));
        // Roll based on turn rate (derivative of yaw)
        d.roll = clamp(d.velocity.x * 5.0, -30.0, 30.0);
    }
    // Wing flap animation
    d.wing_angle = sin(float(pc.tick) * 0.15) * 25.0;
}

// ============================================================================
// PHASE BEHAVIORS
// ============================================================================

// CIRCLING: Fly around fountain in a circle, pick next phase (MC 1.8.9)
void phase_circling(inout Dragon d, Player p, uint env_id, inout uint seed) {
    d.phase_timer++;

    // Update circle angle
    d.circle_angle += CIRCLE_SPEED;
    if (d.circle_angle > 6.283185) d.circle_angle -= 6.283185;

    // Vary altitude with sine wave for more natural movement
    float altitude_wave = sin(d.circle_angle * 2.0) * 10.0;
    float target_altitude = mix(CIRCLE_ALTITUDE_MIN, CIRCLE_ALTITUDE_MAX,
                                (sin(d.circle_angle * 0.5) + 1.0) * 0.5) + altitude_wave;

    // Calculate target position on circle
    d.target_position = vec3(
        FOUNTAIN_CENTER.x + cos(d.circle_angle) * d.circle_radius,
        target_altitude,
        FOUNTAIN_CENTER.z + sin(d.circle_angle) * d.circle_radius
    );

    // Steer toward target
    d.velocity = steer_toward(d.position, d.velocity, d.target_position, CIRCLE_SPEED * 50.0, 0.08);

    // Phase transitions (after minimum circle time) - MC 1.8.9: only strafe/charge
    if (d.phase_timer >= MIN_CIRCLE_TIME) {
        vec3 to_player = p.position - d.position;
        float player_dist = length(to_player);

        // Random phase selection
        float roll = rand(seed);

        // 70% chance: STRAFING (dive attack on player)
        if (roll < 0.007 && d.phase_timer >= MIN_CIRCLE_TIME) {
            d.phase = PHASE_STRAFING;
            d.phase_timer = 0u;
            d.strafe_attacks = 0u;
            d.strafe_attack_count = uint(rand_range(seed, float(MIN_STRAFE_ATTACKS), float(MAX_STRAFE_ATTACKS)));
            d.subphase = 0u;  // 0 = diving, 1 = pulling up
            return;
        }

        // 30% chance: CHARGING (if player is far, >40 blocks)
        if (roll < 0.01 && player_dist > 40.0) {
            d.phase = PHASE_CHARGING;
            d.phase_timer = 0u;
            d.target_position = p.position + vec3(0.0, 2.0, 0.0);
            return;
        }

        // Force strafe transition after max circle time
        if (d.phase_timer >= MAX_CIRCLE_TIME) {
            d.phase = PHASE_STRAFING;
            d.phase_timer = 0u;
            d.strafe_attacks = 0u;
            d.strafe_attack_count = uint(rand_range(seed, float(MIN_STRAFE_ATTACKS), float(MAX_STRAFE_ATTACKS)));
            d.subphase = 0u;
        }
    }
}
                d.subphase = 0u;
            } else {
                d.perch_timer = PERCH_DURATION_TICKS;
                d.breath_timer = 0.0;
                d.damage_taken_while_perched = 0u;
                d.target_position = FOUNTAIN_CENTER + vec3(0.0, 4.0, 0.0);
            }
        }
    }
}

// STRAFING: Attack player while flying past, multiple passes
void phase_strafing(inout Dragon d, Player p, uint env_id, inout uint seed) {
    d.phase_timer++;

    vec3 to_player = p.position - d.position;
    float player_dist = length(to_player);

    if (d.subphase == 0u) {
        // Diving toward player
        vec3 attack_target = p.position + vec3(0.0, 2.0, 0.0);

        // Lead the target based on player velocity
        attack_target += p.velocity * (player_dist / STRAFE_SPEED) * 0.5;

        d.target_position = attack_target;
        d.velocity = steer_toward(d.position, d.velocity, d.target_position, STRAFE_SPEED, 0.12);

        // Add downward component for dive
        if (d.position.y > attack_target.y + 10.0) {
            d.velocity.y -= STRAFE_DIVE_ANGLE;
        }

        // Check if close enough to count as attack
        if (player_dist < 8.0) {
            d.strafe_attacks++;
            d.subphase = 1u;  // Switch to pull-up
            d.attack_cooldown = 20u;  // Cooldown before next attack
        }

        // Timeout - if we've been diving too long, pull up anyway
        if (d.phase_timer > 60u) {
            d.subphase = 1u;
        }
    } else {
        // Pulling up after attack
        d.target_position = d.position + vec3(
            -sin(radians(d.yaw)) * 30.0,
            STRAFE_PULL_UP_HEIGHT - d.position.y + 20.0,
            cos(radians(d.yaw)) * 30.0
        );

        d.velocity = steer_toward(d.position, d.velocity, d.target_position, STRAFE_SPEED * 0.8, 0.1);

        // Once high enough, check if we should do another pass
        if (d.position.y > STRAFE_PULL_UP_HEIGHT) {
            if (d.strafe_attacks < d.strafe_attack_count) {
                // More attacks to do
                d.subphase = 0u;
                d.phase_timer = 0u;
            } else {
                // Done strafing, return to circling
                d.phase = PHASE_CIRCLING;
                d.phase_timer = 0u;
                d.circle_radius = rand_range(seed, CIRCLE_RADIUS_MIN, CIRCLE_RADIUS_MAX);
                d.circle_altitude = rand_range(seed, CIRCLE_ALTITUDE_MIN, CIRCLE_ALTITUDE_MAX);
            }
        }
    }
}

// CHARGING: High-speed dive at player, causes wing damage
void phase_charging(inout Dragon d, Player p, uint env_id, inout uint seed) {
    d.phase_timer++;

    vec3 to_player = p.position - d.position;
    float player_dist = length(to_player);

    // Update target to track player with some lead
    d.target_position = p.position + p.velocity * 0.5 + vec3(0.0, 1.5, 0.0);

    // High speed steering
    d.velocity = steer_toward(d.position, d.velocity, d.target_position, CHARGE_SPEED, 0.15);

    // Steep dive angle
    if (d.position.y > d.target_position.y + 5.0) {
        d.velocity.y -= CHARGE_DIVE_ANGLE * 0.5;
    }

    // End charge conditions:
    // 1. Passed the player (overshot)
    float closing_speed = -dot(normalize(to_player), d.velocity);
    bool overshot = closing_speed < 0.0 && player_dist < 15.0;

    // 2. Very close to player (hit)
    bool hit_player = player_dist < 5.0;

    // 3. Too low (about to hit ground)
    bool too_low = d.position.y < FOUNTAIN_CENTER.y + 10.0;

    // 4. Timeout
    bool timeout = d.phase_timer > 100u;

    if (overshot || hit_player || too_low || timeout) {
        d.phase = PHASE_CIRCLING;
        d.phase_timer = 0u;
        d.circle_radius = rand_range(seed, CIRCLE_RADIUS_MIN, CIRCLE_RADIUS_MAX);

        // Force upward after charge
        d.velocity.y = abs(d.velocity.y) + 1.0;
    }
}

