    } else {
        // Landed - minimal movement, face nearest player
        d.velocity *= 0.1;
        d.position = mix(d.position, perch_target, 0.1);

        // Face toward player
        vec3 to_player = p.position - d.position;
        float player_dist = length(to_player.xz);
        if (player_dist > 1.0) {
            float target_yaw = degrees(atan(to_player.x, to_player.z));
            d.yaw = mix(d.yaw, target_yaw, 0.05);  // Slow turn
        }

        // Breath attack
        d.breath_timer += 1.0;

        // Check if player is in breath cone
        vec3 dragon_forward = vec3(-sin(radians(d.yaw)), 0.0, cos(radians(d.yaw)));
        float player_in_front = dot(normalize(to_player.xzy), dragon_forward);

        // Breath attack hits if player is:
        // - Within range
        // - In front of dragon (within ~60 degree cone)
        // - Timer says so (damage every ~0.5 seconds)
        if (player_dist < PERCH_BREATH_RANGE &&
            player_in_front > 0.5 &&
            uint(d.breath_timer) % 10u == 0u &&
            p.invincibility_timer == 0u) {
            // Damage handled in combat stage
        }

        // Decrement perch timer
        if (d.perch_timer > 0u) {
            d.perch_timer--;
        }

        // Leave conditions:
        // 1. Timer expired (10 seconds)
        // 2. Took heavy damage (>50 damage while perched)
        bool timer_expired = d.perch_timer == 0u;
        bool heavy_damage = d.damage_taken_while_perched > 50u;

        if (timer_expired || heavy_damage) {
            d.phase = PHASE_LEAVING;
            d.phase_timer = 0u;
            d.breath_timer = 0.0;
        }
