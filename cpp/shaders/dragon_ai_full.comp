// DEPRECATED: MC 1.9+ only - LEAVING phase does not exist in MC 1.8.9
#if 0  // Disabled for MC 1.8.9 accuracy
void phase_leaving(inout Dragon d, Player p, uint env_id, inout uint seed) {
    d.phase_timer++;

    // Target: high altitude above fountain
    d.target_position = vec3(
        FOUNTAIN_CENTER.x + cos(d.circle_angle) * 20.0,
        TAKEOFF_TARGET_HEIGHT,
        FOUNTAIN_CENTER.z + sin(d.circle_angle) * 20.0
    );

    d.velocity = steer_toward(d.position, d.velocity, d.target_position, TAKEOFF_SPEED, 0.08);

    // Boost upward
    d.velocity.y += 0.05;

    // Once high enough, return to circling
    if (d.position.y > TAKEOFF_TARGET_HEIGHT - 5.0) {
        d.phase = PHASE_CIRCLING;
        d.phase_timer = 0u;
        d.circle_radius = rand_range(seed, CIRCLE_RADIUS_MIN, CIRCLE_RADIUS_MAX);
        d.circle_altitude = rand_range(seed, CIRCLE_ALTITUDE_MIN, CIRCLE_ALTITUDE_MAX);
    }

    // Timeout - force transition
    if (d.phase_timer > 100u) {
        d.phase = PHASE_CIRCLING;
        d.phase_timer = 0u;
    }
}
#endif  // MC 1.8.9 - phase_leaving disabled

// DYING: Death animation at fountain, terminal state
void phase_dying(inout Dragon d, uint env_id) {
    d.phase_timer++;

    // Fly toward fountain center
    float death_progress = float(d.phase_timer) / 200.0;  // 10 second death animation

    if (death_progress < 0.3) {
        // Phase 1: Fly to fountain
        d.target_position = FOUNTAIN_CENTER + vec3(0.0, 20.0, 0.0);
        d.velocity = steer_toward(d.position, d.velocity, d.target_position, 1.5, 0.05);
    } else if (death_progress < 0.7) {
        // Phase 2: Rise up while spinning
        d.target_position = FOUNTAIN_CENTER + vec3(0.0, 50.0 * ease_out_cubic((death_progress - 0.3) / 0.4), 0.0);
        d.velocity = steer_toward(d.position, d.velocity, d.target_position, 1.0, 0.03);
        d.yaw += 5.0;  // Spin
    } else if (death_progress < 1.0) {
        // Phase 3: Explode (handled by particle system)
        d.velocity *= 0.9;
    } else {
        // Done - dragon fully dead
        d.position = vec3(0.0, -1000.0, 0.0);  // Move off-world
    }
}

// ============================================================================
// MAIN AI UPDATE
// ============================================================================

void update_dragon_ai(uint env_id) {
    if (env_id >= pc.num_envs) return;

    Dragon d = dragons[env_id];
    Player p = players[env_id];
    GameState gs = game_states[env_id];
    uint seed = hash(gs.random_seed ^ env_id ^ pc.tick);

    // Skip if dragon is dead and animation complete
    if (d.health <= 0.0 && d.phase != PHASE_DYING) {
        d.phase = PHASE_DYING;
        d.phase_timer = 0u;
    }

    // Process current phase
    switch (d.phase) {
        case PHASE_CIRCLING:
            phase_circling(d, p, env_id, seed);
            break;

        case PHASE_STRAFING:
            phase_strafing(d, p, env_id, seed);
            break;

        case PHASE_CHARGING:
            phase_charging(d, p, env_id, seed);
            break;

        // MC 1.8.9: PHASE_PERCHING and PHASE_LEAVING do not exist
        // case PHASE_PERCHING:
        //     phase_perching(d, p, env_id, seed);
        //     break;
        // case PHASE_LEAVING:
        //     phase_leaving(d, p, env_id, seed);
        //     break;

        case PHASE_DYING:
            phase_dying(d, env_id);
            break;
    }

    // Apply velocity
    d.position += d.velocity;

    // Arena bounds (keep within End island)
    vec2 from_center = d.position.xz - FOUNTAIN_CENTER.xz;
    float dist_from_center = length(from_center);
    if (dist_from_center > ARENA_RADIUS) {
        d.position.xz = FOUNTAIN_CENTER.xz + normalize(from_center) * ARENA_RADIUS;
        // Steer back toward center
        vec3 to_center = vec3(-from_center.x, 0.0, -from_center.y);
        d.velocity += normalize(to_center) * 0.1;
    }

    // Height bounds
    d.position.y = clamp(d.position.y, FOUNTAIN_CENTER.y + 5.0, 120.0);

    // Apply drag
    d.velocity *= DRAG_AIR;

    // Update facing
    update_dragon_facing(d);

    // Decrement cooldowns
    if (d.attack_cooldown > 0u) d.attack_cooldown--;

    // Write back
    dragons[env_id] = d;
    game_states[env_id].random_seed = seed;
}

// ============================================================================
// COMBAT PROCESSING
// ============================================================================

void process_dragon_combat(uint env_id) {
    if (env_id >= pc.num_envs) return;

    Dragon d = dragons[env_id];
    Player p = players[env_id];

    if (d.health <= 0.0 || d.phase == PHASE_DYING) return;
    if ((p.flags & 8u) != 0u) return;  // Player dead

    vec3 to_player = p.position - d.position;
    float player_dist = length(to_player);

    // Contact damage based on phase
    if (p.invincibility_timer == 0u) {
        // Charging: high damage + wing knockback
        if (d.phase == PHASE_CHARGING && player_dist < 6.0 && d.attack_cooldown == 0u) {
            p.health = max(0.0, p.health - CHARGE_DAMAGE);
            p.invincibility_timer = 10u;

            // Heavy knockback in charge direction
            vec3 kb = normalize(d.velocity) * WING_KNOCKBACK;
            kb.y = 0.5;
            p.velocity += kb;

            d.attack_cooldown = 20u;
            rewards[env_id] -= 5.0;
        }

        // Strafing: moderate damage during dive
        if (d.phase == PHASE_STRAFING && d.subphase == 0u && player_dist < 5.0 && d.attack_cooldown == 0u) {
            p.health = max(0.0, p.health - 3.0);
            p.invincibility_timer = 10u;

            vec3 kb = normalize(d.velocity) * 8.0;
            kb.y = 0.4;
            p.velocity += kb;

            d.attack_cooldown = 20u;
            rewards[env_id] -= 3.0;
        }

        // MC 1.8.9: No perching/breath attack - dragon never lands
        // Perching breath attack damage removed (1.9+ feature)

        // General body collision (any phase)
        if (player_dist < DRAGON_BODY_RADIUS + 1.0 && d.attack_cooldown == 0u) {
            p.health = max(0.0, p.health - 2.0);
            p.invincibility_timer = 10u;

            // Push player away
            vec3 kb = normalize(to_player) * 5.0;
            kb.y = 0.3;
            p.velocity += kb;
        }
    }

    // Player death check
    if (p.health <= 0.0) {
        p.flags |= 8u;  // FLAG_DEAD
        dones[env_id] = 1u;
        rewards[env_id] -= 50.0;
    }

    players[env_id] = p;
    dragons[env_id] = d;
}

// ============================================================================
// MAIN
// ============================================================================

void main() {
    uint env_id = gl_GlobalInvocationID.x;

    switch (pc.stage) {
        case 0u: update_dragon_ai(env_id); break;
        case 1u: process_dragon_combat(env_id); break;
    }
}
