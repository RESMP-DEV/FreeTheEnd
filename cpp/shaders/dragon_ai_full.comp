#version 450

// MC 1.8.9 Ender Dragon AI - Accurate Phase Implementation
// In 1.8.9, the dragon ONLY circles and performs dive attacks.
// NO perching on fountain, NO breath attack (those were added in 1.9).
// The dragon heals from end crystals and takes 10 damage when a connected crystal is destroyed.
// MoltenVK compatible - all bindings in single descriptor set

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

layout(push_constant) uniform PushConstants {
    uint stage;
    uint num_envs;
    uint tick;
    uint random_seed;
} pc;

// ============================================================================
// CONSTANTS
// ============================================================================

// Physics
const float GRAVITY = -0.08;
const float DRAG_AIR = 0.98;

// Dragon phases (MC 1.8.9 - NO perching or breath attack)
const uint PHASE_CIRCLING = 0u;
const uint PHASE_STRAFING = 1u;   // Dive attack passes
const uint PHASE_CHARGING = 2u;   // Direct charge at player
const uint PHASE_DYING = 3u;      // Death animation

// Dragon movement parameters
const float CIRCLE_RADIUS_MIN = 50.0;
const float CIRCLE_RADIUS_MAX = 80.0;
const float CIRCLE_ALTITUDE_MIN = 70.0;
const float CIRCLE_ALTITUDE_MAX = 90.0;
const float CIRCLE_SPEED = 0.03;

const float STRAFE_SPEED = 2.5;
const float STRAFE_DIVE_ANGLE = 0.3;
const float STRAFE_PULL_UP_HEIGHT = 40.0;

const float CHARGE_SPEED = 4.0;
const float CHARGE_DIVE_ANGLE = 0.5;

// MC 1.8.9: No landing/perching, dragon only circles and attacks

// Dragon body
const float DRAGON_MAX_HEALTH = 200.0;
const float DRAGON_BODY_RADIUS = 4.0;
const float DRAGON_HEAD_RADIUS = 2.5;
const vec3 DRAGON_HEAD_OFFSET = vec3(0.0, 0.0, 6.0);

// Damage values
const float HEAD_DAMAGE_MULT = 4.0;
const float BODY_DAMAGE_MULT = 1.0;
const float WING_KNOCKBACK = 12.0;
const float CHARGE_DAMAGE = 5.0;

// Phase transition probabilities (per tick)
const float CIRCLE_TO_STRAFE_CHANCE = 0.003;  // ~60% over 5-10 seconds
const float CIRCLE_TO_CHARGE_CHANCE = 0.0015; // ~30% if player far
const float CIRCLE_TO_PERCH_CHANCE = 0.0005;  // ~10% or forced if no crystals
const float MIN_CIRCLE_TIME = 100u;           // 5 seconds minimum
const float MAX_CIRCLE_TIME = 200u;           // 10 seconds maximum

// Strafe parameters
const uint MIN_STRAFE_ATTACKS = 3u;
const uint MAX_STRAFE_ATTACKS = 5u;

// Arena bounds
const float ARENA_RADIUS = 100.0;
const float FOUNTAIN_RADIUS = 5.0;
const vec3 FOUNTAIN_CENTER = vec3(0.0, 64.0, 0.0);

// Crystal count
const uint NUM_CRYSTALS = 10u;

// ============================================================================
// STRUCTURES
// ============================================================================

struct Dragon {
    vec3 position;
    float yaw;
    vec3 velocity;
    float pitch;

    float health;
    uint phase;
    uint phase_timer;
    uint subphase;

    vec3 target_position;
    float circle_angle;

    float circle_radius;
    float circle_altitude;
    uint strafe_attacks;
    uint strafe_attack_count;

    float breath_timer;
    uint perch_timer;
    uint attack_cooldown;
    uint damage_taken_while_perched;

    float wing_angle;
    float body_pitch;
    float roll;
    uint flags;
};

struct Player {
    vec3 position;
    float yaw;
    vec3 velocity;
    float pitch;
    float health;
    float hunger;
    float saturation;
    float exhaustion;
    uint flags;
    uint invincibility_timer;
    uint attack_cooldown;
    uint weapon_slot;
    float arrow_charge;
    uint arrows;
    uint reserved[2];
};

struct Crystal {
    vec3 position;
    float is_alive;
};

struct GameState {
    uint tick_number;
    uint game_flags;
    uint random_seed;
    float delta_time;
    uint crystals_destroyed;
    uint dragon_hits;
    uint player_deaths;
    float best_dragon_damage;
};

