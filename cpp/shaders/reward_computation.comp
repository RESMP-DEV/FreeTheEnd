#version 450

/*
 * reward_computation.comp - Reward computation for all 6 curriculum stages
 *
 * This shader computes dense rewards for the Free The End speedrun curriculum.
 * Each stage has milestone-based rewards to guide exploration and learning.
 *
 * Curriculum Stages:
 *   1: Basic Survival    - Wood, tools, first night
 *   2: Resource Gathering- Iron, bucket, furnace
 *   3: Nether Navigation - Portal, fortress, blaze rods
 *   4: Enderman Hunting  - Ender pearls collection
 *   5: Stronghold Finding- Eyes of ender, portal activation
 *   6: Dragon Fight      - Crystal destruction, dragon kill
 *
 * Buffer layout matches game_tick_mvk.comp and inventory_ops.comp
 */

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

// ============================================================================
// PUSH CONSTANTS
// ============================================================================

layout(push_constant) uniform PushConstants {
    uint curriculum_stage;  // 1-6 active curriculum stage
    uint num_envs;          // Number of parallel environments
    uint tick;              // Current tick number
    uint flags;             // Bit flags for options
} pc;

