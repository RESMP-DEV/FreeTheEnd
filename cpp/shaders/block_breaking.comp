#version 450
#extension GL_EXT_shader_atomic_float : enable

// Block Breaking Compute Shader
// Processes block mining for multiple agents in parallel
// Input: player positions, look directions, tools, blocks being mined
// State: break_progress per agent
// Output: broken flags, drops to spawn

layout(local_size_x = 64, local_size_y = 1, local_size_z = 1) in;

