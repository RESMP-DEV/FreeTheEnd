// Tool types
const uint TOOL_NONE = 0;
const uint TOOL_WOOD_PICKAXE = 1;
const uint TOOL_STONE_PICKAXE = 2;
const uint TOOL_IRON_PICKAXE = 3;
const uint TOOL_DIAMOND_PICKAXE = 4;
const uint TOOL_GOLD_PICKAXE = 5;
const uint TOOL_WOOD_AXE = 6;
const uint TOOL_STONE_AXE = 7;
const uint TOOL_IRON_AXE = 8;
const uint TOOL_DIAMOND_AXE = 9;
const uint TOOL_GOLD_AXE = 10;
const uint TOOL_WOOD_SHOVEL = 11;
const uint TOOL_STONE_SHOVEL = 12;
const uint TOOL_IRON_SHOVEL = 13;
const uint TOOL_DIAMOND_SHOVEL = 14;
const uint TOOL_GOLD_SHOVEL = 15;
const uint TOOL_SHEARS = 16;
const uint TOOL_SWORD = 17;

// Tool tiers for speed multiplier
const float TOOL_TIER_SPEED[6] = float[6](
    1.0,   // 0: Hand/None
    2.0,   // 1: Wood
    4.0,   // 2: Stone
    6.0,   // 3: Iron
    8.0,   // 4: Diamond
    12.0   // 5: Gold
);

// Block material types for tool matching
const uint MAT_NONE = 0;
const uint MAT_STONE = 1;
const uint MAT_WOOD = 2;
const uint MAT_DIRT = 3;
const uint MAT_PLANT = 4;
const uint MAT_WOOL = 5;

struct AgentInput {
    vec3 position;     // Player eye position
    float _pad0;
    vec3 look_dir;     // Normalized look direction
    float _pad1;
    uint tool_id;      // Currently held tool
    uint target_block; // Block ID being mined (from world lookup)
    ivec3 target_pos;  // World position of target block
    uint mining_face;  // Face being mined (0-5)
};

struct BreakingState {
    float progress;    // 0.0 to 1.0, resets if target changes
    ivec3 last_target; // Last targeted block position
    uint last_block;   // Last targeted block ID
    float _pad[3];
};

struct BreakResult {
    uint broken;       // 1 if block was broken this tick
    uint block_id;     // Block that was broken
    ivec3 position;    // Where it was broken
    uint drop_count;   // Number of drops
    uint drop_ids[4];  // Up to 4 different drop item IDs
    uint drop_amounts[4]; // Amount per drop type
};

struct WorldModification {
    ivec3 position;
    uint new_block_id;
    uint new_metadata;
    uint modification_type; // 0=break, 1=place, 2=update
    uint agent_id;
    uint _pad;
};

// Input/Output bindings
layout(set = 0, binding = 0, std430) readonly buffer AgentInputBuffer {
    AgentInput agents[];
} agent_input;

layout(set = 0, binding = 1, std430) buffer BreakingStateBuffer {
    BreakingState states[];
} breaking_state;

layout(set = 0, binding = 2, std430) writeonly buffer BreakResultBuffer {
    BreakResult results[];
} break_results;

layout(set = 0, binding = 3, std430) buffer WorldModBuffer {
    uint modification_count;
    uint _pad[3];
    WorldModification modifications[];
} world_mods;

layout(push_constant) uniform PushConstants {
    float delta_time;      // Time since last tick in seconds (typically 0.05 for 20 TPS)
    uint agent_count;      // Number of is_active agents
    uint max_modifications; // Max world modifications per tick
} pc;

// Get tool tier (0-5) from tool ID
uint getToolTier(uint tool_id) {
    if (tool_id == TOOL_NONE) return 0;
    if (tool_id <= 5) return tool_id; // Pickaxes
    if (tool_id <= 10) return tool_id - 5; // Axes
    if (tool_id <= 15) return tool_id - 10; // Shovels
    return 1; // Shears/Sword = wood tier
}

// Check if tool is correct type for block
bool isCorrectToolType(uint tool_id, uint block_id) {
    // Pickaxes for stone-type blocks
    if (tool_id >= TOOL_WOOD_PICKAXE && tool_id <= TOOL_GOLD_PICKAXE) {
        if (block_id == 1 || block_id == 4 || block_id == 48 || // Stone, Cobble, Mossy Cobble
            block_id == 98 || // Stone Bricks
            (block_id >= 14 && block_id <= 16) || // Ores
            block_id == 21 || block_id == 22 || // Lapis
            block_id == 56 || block_id == 57 || // Diamond
            block_id == 41 || block_id == 42 || // Gold/Iron blocks
            block_id == 49) // Obsidian
            return true;
    }
    // Axes for wood-type blocks
    if (tool_id >= TOOL_WOOD_AXE && tool_id <= TOOL_GOLD_AXE) {
        if (block_id == 5 || block_id == 17 || block_id == 162 || // Planks, Log, Log2
            block_id == 47 || block_id == 54 || block_id == 58 || // Bookshelf, Chest, Crafting
            block_id == 85 || block_id == 107) // Fence, Gate
            return true;
    }
    // Shovels for dirt-type blocks
    if (tool_id >= TOOL_WOOD_SHOVEL && tool_id <= TOOL_GOLD_SHOVEL) {
        if (block_id == 2 || block_id == 3 || block_id == 12 || block_id == 13 || // Grass, Dirt, Sand, Gravel
            block_id == 60 || block_id == 78 || block_id == 80 || block_id == 82) // Farmland, Snow, Clay
            return true;
    }
    // Shears for leaves and wool
    if (tool_id == TOOL_SHEARS) {
        if (block_id == 18 || block_id == 161 || block_id == 35 || block_id == 30) // Leaves, Wool, Cobweb
            return true;
    }
    return false;
}

// Check if block requires specific tool tier to drop
uint getRequiredTier(uint block_id) {
    // Iron and up required
    if (block_id == 56 || block_id == 57) return 3; // Diamond
    if (block_id == 14 || block_id == 21 || block_id == 22) return 3; // Gold ore, Lapis
    if (block_id == 129 || block_id == 133) return 3; // Emerald
    if (block_id == 49) return 4; // Obsidian requires diamond
    // Stone required
    if (block_id == 15 || block_id == 16) return 2; // Iron ore, Coal ore
    if (block_id == 73 || block_id == 74) return 3; // Redstone ore
    // Wood pickaxe okay
    if (block_id == 1 || block_id == 4 || block_id == 48) return 1; // Stone, Cobble
    return 0;
}

// Calculate break speed multiplier
float getBreakSpeedMultiplier(uint tool_id, uint block_id) {
    float multiplier = 1.0;

    if (isCorrectToolType(tool_id, block_id)) {
        uint tier = getToolTier(tool_id);
        multiplier = TOOL_TIER_SPEED[tier];
    }

    return multiplier;
}

// Calculate drops for a broken block
void calculateDrops(uint block_id, uint tool_tier, out uint drop_count, out uint drop_ids[4], out uint drop_amounts[4]) {
    drop_count = 0;
    for (int i = 0; i < 4; i++) {
        drop_ids[i] = 0;
        drop_amounts[i] = 0;
    }

    // Check if correct tier is met
    uint req_tier = getRequiredTier(block_id);
    if (tool_tier < req_tier) {
        return; // No drops without correct tool
    }

    // Map block drops (simplified)
    switch (block_id) {
        case 1: // Stone -> Cobblestone
            drop_count = 1;
            drop_ids[0] = 4;
            drop_amounts[0] = 1;
            break;
        case 2: // Grass -> Dirt
            drop_count = 1;
            drop_ids[0] = 3;
            drop_amounts[0] = 1;
            break;
        case 3: // Dirt
        case 4: // Cobblestone
        case 5: // Planks
        case 17: // Log
            drop_count = 1;
            drop_ids[0] = block_id;
            drop_amounts[0] = 1;
            break;
        case 14: // Gold Ore
            drop_count = 1;
            drop_ids[0] = 14;
            drop_amounts[0] = 1;
            break;
        case 15: // Iron Ore
            drop_count = 1;
            drop_ids[0] = 15;
            drop_amounts[0] = 1;
            break;
        case 16: // Coal Ore -> Coal
            drop_count = 1;
            drop_ids[0] = 263; // Coal item ID
            drop_amounts[0] = 1;
            break;
        case 21: // Lapis Ore -> Lapis (4-8, use 6)
            drop_count = 1;
            drop_ids[0] = 351; // Dye with meta 4
            drop_amounts[0] = 6;
            break;
        case 56: // Diamond Ore -> Diamond
            drop_count = 1;
            drop_ids[0] = 264; // Diamond item ID
            drop_amounts[0] = 1;
            break;
        case 73: // Redstone Ore -> Redstone (4-5)
        case 74:
            drop_count = 1;
            drop_ids[0] = 331; // Redstone dust
            drop_amounts[0] = 5;
            break;
        case 18: // Leaves -> possibly sapling (1/20 chance, handle in CPU)
        case 161:
            drop_count = 0;
            break;
        case 13: // Gravel -> possibly flint (1/10 chance, handle in CPU)
            drop_count = 1;
            drop_ids[0] = 13;
            drop_amounts[0] = 1;
            break;
        default:
            drop_count = 1;
            drop_ids[0] = block_id;
            drop_amounts[0] = 1;
            break;
    }
}

void main() {
    uint agent_id = gl_GlobalInvocationID.x;
    if (agent_id >= pc.agent_count) return;

    AgentInput agent_in = agent_input.agents[agent_id];
    BreakingState state = breaking_state.states[agent_id];

    // Initialize result to not broken
    BreakResult result;
    result.broken = 0;
    result.block_id = 0;
    result.position = ivec3(0);
    result.drop_count = 0;
    for (int i = 0; i < 4; i++) {
        result.drop_ids[i] = 0;
        result.drop_amounts[i] = 0;
    }

    uint block_id = agent_in.target_block;
    ivec3 target_pos = agent_in.target_pos;

    // Check if target changed
    if (state.last_target != target_pos || state.last_block != block_id) {
        state.progress = 0.0;
        state.last_target = target_pos;
        state.last_block = block_id;
    }

    // Skip unbreakable or air blocks
    float hardness = HARDNESS_TABLE[block_id];
    if (hardness < 0.0 || block_id == 0) {
        breaking_state.states[agent_id] = state;
        break_results.results[agent_id] = result;
        return;
    }

    // Calculate break time
    float speed_mult = getBreakSpeedMultiplier(agent_in.tool_id, block_id);

    // Base break time formula: hardness * 1.5 / speed_mult (if correct tool)
    // or hardness * 5.0 / speed_mult (if wrong tool)
    float break_time;
    if (isCorrectToolType(agent_in.tool_id, block_id)) {
        break_time = hardness * 1.5 / speed_mult;
    } else {
        break_time = hardness * 5.0;
    }

    // Minimum break time
    if (break_time < 0.05) break_time = 0.05;

    // Add progress based on delta time
    float progress_increment = pc.delta_time / break_time;
    state.progress += progress_increment;

    // Check if broken
    if (state.progress >= 1.0) {
        result.broken = 1;
        result.block_id = block_id;
        result.position = target_pos;

        // Calculate drops
        uint tool_tier = getToolTier(agent_in.tool_id);
        calculateDrops(block_id, tool_tier, result.drop_count, result.drop_ids, result.drop_amounts);

        // Queue world modification
        uint mod_index = atomicAdd(world_mods.modification_count, 1);
        if (mod_index < pc.max_modifications) {
            WorldModification mod;
            mod.position = target_pos;
            mod.new_block_id = 0; // Air
            mod.new_metadata = 0;
            mod.modification_type = 0; // Break
            mod.agent_id = agent_id;
            mod._pad = 0;
            world_mods.modifications[mod_index] = mod;
        }

        // Reset state
        state.progress = 0.0;
    }

    // Write outputs
    breaking_state.states[agent_id] = state;
    break_results.results[agent_id] = result;
}
